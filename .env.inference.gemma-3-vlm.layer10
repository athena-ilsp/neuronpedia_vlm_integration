# VLM change: inference config for HookedGemma3 VLM with custom SAEs
MODEL_ID=gemma-3-4b-it
OVERRIDE_MODEL_ID=google/gemma-3-4b-it
MODEL_DTYPE=bfloat16
SAE_DTYPE=bfloat16
TOKEN_LIMIT=2048

# VLM change: enable VLM mode (loads HookedGemma3 + VLMModelAdapter instead of HookedTransformer)
VLM=true

# VLM change: use GPU 1 (15GB free)
CUDA_DEVICE=1
NVIDIA_VISIBLE_DEVICES=1
CUDA_VISIBLE_DEVICES=0

# VLM change: tell inference server which SAE sets to load (must match keys in VLM_SAE_PATHS)
SAE_SETS=["SAE-200m-8x","Transcoders-200m-16x","Transcoders-300m-16x"]

# VLM change: path to vlm_transcoder_circuits repo inside the container
# The compose.inference.dev.yaml mounts ../apps/inference, so for the VLM repo
# you need to also mount it (see note below) or set this to the container path
VLM_REPO_PATH=/vlm_transcoder_circuits


# VLM change: container-side path (host dir is mounted at /sae_weights via compose.inference.vlm.yaml)
# key must match the source ID registered in the DB (seed-vlm.ts SOURCES dict)
VLM_SAE_SET_NAME=vlm-sae
VLM_SAE_PATHS='
{
